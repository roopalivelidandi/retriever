{
  "name": "world_cities_custom",
  "title": "World Cities Dataset",
  "description": "Dataset containing major cities of the world with country and population datails.",
  "homepage": "https://github.com/datasets/world-cities",
  "resources": [
    {
      "name":"world_cities",
      "path":"https://raw.githubusercontent.com/datasets/world-cities/master/data/world-cities.csv",
      "schema":{
        "fields": [
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "country",
            "type": "string"
          },
          {
            "name": "subcountry",
            "type": "string"
          },
          {
            "name": "geonameid",
            "type": "integer"
          }
        ]
      }
    }
  ]
}
